{
  "$schema": "../pet-sequence-manifest.schema.json",
  "schemaVersion": "pet-sequence-manifest/v1",
  "skin": "bluebot",
  "petId": "bluebot",
  "displayName": "Bluebot v7 Acting",
  "assetVersion": "7.0.0",
  "packageType": "runtime",
  "variant": "bluebot-independent-acting-v7",
  "format": "webp",
  "size": 128,
  "designSize": 128,
  "stateOrder": [
    "idle",
    "reading",
    "running",
    "judging",
    "success",
    "needs-fix"
  ],
  "transitionOrder": [
    "reading_to_running",
    "running_to_judging",
    "judging_to_success",
    "judging_to_needs-fix"
  ],
  "states": {
    "idle": {
      "frames": 24,
      "fps": 12,
      "loop": true
    },
    "reading": {
      "frames": 24,
      "fps": 12,
      "loop": true
    },
    "running": {
      "frames": 24,
      "fps": 14,
      "loop": true
    },
    "judging": {
      "frames": 24,
      "fps": 12,
      "loop": true
    },
    "success": {
      "frames": 20,
      "fps": 14,
      "loop": false,
      "next": "idle"
    },
    "needs-fix": {
      "frames": 20,
      "fps": 10,
      "loop": false,
      "next": "idle"
    }
  },
  "transitions": {
    "reading_to_running": {
      "frames": 10,
      "fps": 14,
      "from": "reading",
      "to": "running",
      "loop": false
    },
    "running_to_judging": {
      "frames": 10,
      "fps": 14,
      "from": "running",
      "to": "judging",
      "loop": false
    },
    "judging_to_success": {
      "frames": 10,
      "fps": 14,
      "from": "judging",
      "to": "success",
      "loop": false
    },
    "judging_to_needs-fix": {
      "frames": 10,
      "fps": 14,
      "from": "judging",
      "to": "needs-fix",
      "loop": false
    }
  },
  "exports": {
    "128": {
      "format": "webp",
      "alpha": true,
      "role": "runtime"
    },
    "96": {
      "format": "webp",
      "alpha": true,
      "role": "runtime"
    },
    "64": {
      "format": "webp",
      "alpha": true,
      "role": "runtime"
    }
  },
  "pathTemplate": "{size}/{state}/pet_{skin}_{state}_{frame}.webp",
  "transitionPathTemplate": "{size}/transitions/{transition}/pet_{skin}_{transition}_{frame}.webp",
  "runtime": {
    "defaultSize": 128,
    "runtimeSizes": [
      128,
      96,
      64
    ],
    "sourceSizes": [],
    "runtimePackageName": "bluebot-sequence-v7-runtime",
    "preload": {
      "states": [
        "idle"
      ],
      "transitions": []
    },
    "lazyLoad": {
      "states": true,
      "transitions": true
    },
    "excludedFromRuntime": [
      "512",
      "256",
      "previews"
    ],
    "packageBytes": 1996122
  },
  "playback": {
    "defaultTransitionPolicy": "play-transition-when-available",
    "loopingStateSwitchPolicy": {
      "mode": "wait-for-sync-frame",
      "fallback": "cut-at-loop-boundary"
    },
    "syncTransitions": {
      "running_to_judging": {
        "fromState": "running",
        "toState": "judging",
        "preferredEntryFrame": 0,
        "compatibleEntryFrames": [
          0,
          12
        ],
        "transitionStartFrame": 0,
        "maxWaitMs": 1500,
        "reason": "Transition frame 000 is generated from the running loop entry pose for v7 sync."
      }
    }
  },
  "actingProfile": {
    "role": "default pet",
    "id": "default-engineer",
    "summary": "Reliable default Coding Coach companion with calm mechanical acting.",
    "motionLanguage": [
      "mechanical",
      "centered",
      "precise",
      "low distraction"
    ],
    "signatureParts": [
      "face screen",
      "antenna light",
      "small diagnostic panel",
      "tiny floating keyboard"
    ],
    "stateGestures": {
      "idle": "calibrated standby with tiny screen blink and antenna pulse",
      "reading": "face-screen scan line while studying an abstract diagnostic panel",
      "running": "precise alternating mechanical hand typing on a tiny floating keyboard",
      "judging": "neutral diagnostic panel with slow cyan light pulse",
      "success": "compact confirmation hop with tiny cyan/yellow sparkles",
      "needs-fix": "small amber maintenance notice and supportive raised-hand hint"
    },
    "transitionGestures": {
      "reading_to_running": "diagnostic panel lowers and keyboard rises",
      "running_to_judging": "keyboard folds into diagnostic panel from a sync typing pose",
      "judging_to_success": "panel fades as antenna light brightens into the hop",
      "judging_to_needs-fix": "panel fades into amber alert dot and hand hint"
    }
  },
  "qa": {
    "safePaddingTarget": "important pixels inside the central 80% of the 512 canvas",
    "distinctActingSystem": "Reliable default Coding Coach companion with calm mechanical acting.",
    "noRuntimeLayering": true
  },
  "notes": [
    "v7 uses separate generated action renderers per pet, not one shared animation skeleton.",
    "All runtime assets are flattened transparent frames; no independent body-part animation is required at runtime.",
    "The state machine semantics remain unchanged from Coding Coach pet v6."
  ],
  "packageBytes": 1996122
}
